{#
  Relations Page Macros
  
  Reusable components for the Relations management page.
  Follows WindX Admin system styling.
#}

{# Entity Card Macro #}
{% macro entity_card(title, entity_type, entities, fields, independent=false) %}
<div class="card entity-card" data-entity-type="{{ entity_type }}">
    <div class="card-header">
        <h3 class="card-title">{{ title }}</h3>
        {% if independent %}
        <span class="badge badge-secondary">Independent</span>
        {% endif %}
    </div>
    
    <div class="card-body">
        <input type="hidden" name="{{ entity_type }}_entity_id" value="">
        
        <div class="form-row">
            <div class="form-fields">
                {% for field in fields %}
                <div class="form-group">
                    <label class="form-label" for="{{ entity_type }}_{{ field.name.replace('.', '_') }}">
                        {{ field.label }}
                        {% if field.required %}<span class="required">*</span>{% endif %}
                    </label>
                    
                    {% if field.type == 'textarea' %}
                    <textarea 
                        class="form-control" 
                        id="{{ entity_type }}_{{ field.name.replace('.', '_') }}"
                        name="{{ entity_type }}_{{ field.name }}"
                        placeholder="Enter {{ field.label.lower() }}..."
                        rows="2"
                    ></textarea>
                    {% elif field.type == 'checkbox' %}
                    <div class="checkbox-wrapper">
                        <input 
                            type="checkbox" 
                            id="{{ entity_type }}_{{ field.name.replace('.', '_') }}"
                            name="{{ entity_type }}_{{ field.name }}"
                            class="form-checkbox"
                        >
                        <label for="{{ entity_type }}_{{ field.name.replace('.', '_') }}" class="checkbox-label-text">Yes</label>
                    </div>
                    {% else %}
                    <input 
                        type="{{ field.type }}" 
                        class="form-control" 
                        id="{{ entity_type }}_{{ field.name.replace('.', '_') }}"
                        name="{{ entity_type }}_{{ field.name }}"
                        placeholder="Enter {{ field.label.lower() }}..."
                        {% if field.step %}step="{{ field.step }}"{% endif %}
                    >
                    {% endif %}
                </div>
                {% endfor %}
            </div>
            
            <div class="form-image">
                <div class="image-upload-box" onclick="RelationsManager.triggerImageUpload('{{ entity_type }}')">
                    <div class="image-placeholder" id="{{ entity_type }}_placeholder">
                        <span class="upload-icon">+</span>
                        <span class="upload-text">Upload Image</span>
                        <span class="upload-hint">Click or drag & drop</span>
                    </div>
                    <img src="" alt="Preview" class="preview-image hidden" id="{{ entity_type }}_preview">
                    <div class="image-overlay hidden" id="{{ entity_type }}_overlay">
                        <span class="change-text">Change</span>
                    </div>
                </div>
                <input type="file" class="hidden" id="{{ entity_type }}_file" accept="image/*" onchange="RelationsManager.handleImageSelect(event, '{{ entity_type }}')">
                <span class="image-label">{{ title }} Image</span>
            </div>
        </div>
    </div>
</div>
{% endmacro %}
