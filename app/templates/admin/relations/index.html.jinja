{% extends "admin/base.html.jinja" %}
{% import "components/rbac_helpers.html.jinja" as rbac with context %}

{% block title %}Relations - WindX Admin{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="stylesheet" href="/static/css/relations.css?v=5">
{% endblock %}

{% block content %}
<div class="relations-page">
    <!-- Page Header -->
    <div class="page-header">
        <h1 class="page-title">Relations Manager</h1>
        <p class="page-subtitle">Create entities and link them together to define valid product paths.</p>
    </div>

    <!-- Tabs -->
    <div class="tabs">
        <nav>
            <button class="tab-btn active" data-tab="entities" onclick="RelationsManager.showTab('entities')">
                <i class="fa-solid fa-plus-circle"></i> Add Entities
            </button>
            <button class="tab-btn" data-tab="view" onclick="RelationsManager.showTab('view')">
                <i class="fa-solid fa-list"></i> View All
            </button>
        </nav>
    </div>

    <!-- Tab: Add Entities -->
    <div id="tab-content-entities">
        <div class="card">
            <h3 class="card-title">Add New Entity</h3>
            
            <!-- Entity Type Selector -->
            <div class="form-group" style="max-width: 300px;">
                <label class="form-label">Entity Type</label>
                <select id="entityType" class="form-control" onchange="RelationsManager.updateEntityForm()">
                    <option value="">-- Select Type --</option>
                    <option value="material">Material</option>
                    <option value="opening_system">Opening System</option>
                    <option value="color">Color</option>
                    <option value="company">Company</option>
                    <option value="system_series">System Series</option>
                </select>
            </div>

            <!-- Dynamic Form -->
            <div id="entityForm" class="hidden">
                <!-- Main Form Layout: Fields on left, Image on right -->
                <div class="form-with-image">
                    <!-- Left: Form Fields (single column) -->
                    <div class="form-fields-column">
                        <div class="form-group">
                            <label class="form-label">Name <span class="required">*</span></label>
                            <input type="text" id="entityName" class="form-control" placeholder="Enter name...">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Price From (€)</label>
                            <input type="number" id="entityPrice" class="form-control" placeholder="0.00" step="0.01">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Description</label>
                            <textarea id="entityDescription" class="form-control" rows="2" placeholder="Optional description..."></textarea>
                        </div>
                        
                        <!-- Material Extra Fields -->
                        <div id="materialFields" class="hidden">
                            <div class="form-group">
                                <label class="form-label">Density</label>
                                <input type="number" id="materialDensity" class="form-control" placeholder="0.00" step="0.01">
                            </div>
                        </div>
                        
                        <!-- System Series Extra Fields -->
                        <div id="seriesFields" class="hidden">
                            <div class="form-group">
                                <label class="form-label">Width (mm)</label>
                                <input type="number" id="seriesWidth" class="form-control" placeholder="0" step="0.01">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Chambers</label>
                                <input type="number" id="seriesChambers" class="form-control" placeholder="0">
                            </div>
                            <div class="form-group">
                                <label class="form-label">U-Value</label>
                                <input type="number" id="seriesUValue" class="form-control" placeholder="0.00" step="0.01">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Seals</label>
                                <input type="number" id="seriesSeals" class="form-control" placeholder="0">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Characteristics</label>
                                <input type="text" id="seriesCharacteristics" class="form-control" placeholder="Enter characteristics...">
                            </div>
                        </div>
                        
                        <!-- Color Extra Fields -->
                        <div id="colorFields" class="hidden">
                            <div class="form-group">
                                <label class="form-label">Color Code</label>
                                <input type="text" id="colorCode" class="form-control" placeholder="e.g., #FFFFFF">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Has Lamination</label>
                                <select id="colorLamination" class="form-control">
                                    <option value="false">No</option>
                                    <option value="true">Yes</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Right: Image Upload -->
                    <div class="image-column">
                        <label class="form-label">Image</label>
                        <div class="image-upload-box" onclick="document.getElementById('entityImage').click()">
                            <div class="placeholder" id="imagePlaceholder">
                                <i class="fa-solid fa-cloud-upload-alt"></i>
                                <span>Upload</span>
                            </div>
                            <img src="" alt="Preview" class="hidden" id="imagePreview">
                            <div class="overlay hidden" id="imageOverlay">Change</div>
                        </div>
                        <input type="file" id="entityImage" class="hidden" accept="image/*" onchange="RelationsManager.handleImageSelect(event)">
                        <button type="button" id="clearImageBtn" class="btn-clear-image hidden" onclick="RelationsManager.clearImage(event)">
                            <i class="fa-solid fa-times"></i> Clear
                        </button>
                    </div>
                </div>

                <!-- Company Link Section -->
                <div id="companyLinks" class="hidden link-section">
                    <h4><i class="fa-solid fa-link"></i> Link to Material</h4>
                    <div class="form-group" style="max-width: 300px;">
                        <label class="form-label">Material</label>
                        <select id="companyMaterial" class="form-control">
                            <option value="">Select material...</option>
                        </select>
                    </div>
                </div>

                <!-- System Series Link Section -->
                <div id="seriesLinks" class="hidden link-section">
                    <h4><i class="fa-solid fa-link"></i> Link to Create Path</h4>
                    <div class="form-grid-3">
                        <div class="form-group">
                            <label class="form-label">Company → Material</label>
                            <select id="seriesCompanyMaterial" class="form-control">
                                <option value="">Select...</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Opening System</label>
                            <select id="seriesOpening" class="form-control">
                                <option value="">Select...</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Colors <span class="multi-select-hint">(multi-select)</span></label>
                            <select id="seriesColors" class="form-control" onchange="RelationsManager.addColorChip()">
                                <option value="">Select colors...</option>
                            </select>
                            <div id="colorChips" class="chips-container"></div>
                        </div>
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="form-actions-inline">
                    <button class="btn btn-primary" onclick="RelationsManager.recordEntity()">
                        <i class="fa-solid fa-save"></i> Record
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab: View All -->
    <div id="tab-content-view" class="hidden">
        <!-- Summary Cards -->
        <div class="summary-grid">
            <div class="summary-card cyan">
                <div class="icon"><i class="fa-solid fa-cubes"></i></div>
                <div class="count" id="countMaterial">0</div>
                <div class="label">Materials</div>
            </div>
            <div class="summary-card blue">
                <div class="icon"><i class="fa-solid fa-door-open"></i></div>
                <div class="count" id="countOpening">0</div>
                <div class="label">Opening Systems</div>
            </div>
            <div class="summary-card pink">
                <div class="icon"><i class="fa-solid fa-palette"></i></div>
                <div class="count" id="countColor">0</div>
                <div class="label">Colors</div>
            </div>
            <div class="summary-card emerald">
                <div class="icon"><i class="fa-solid fa-building"></i></div>
                <div class="count" id="countCompany">0</div>
                <div class="label">Companies</div>
            </div>
            <div class="summary-card amber">
                <div class="icon"><i class="fa-solid fa-layer-group"></i></div>
                <div class="count" id="countSeries">0</div>
                <div class="label">System Series</div>
            </div>
        </div>

        <!-- Company → Material Links -->
        <div class="card">
            <h3 class="card-title"><i class="fa-solid fa-building"></i> Company → Material Links</h3>
            <div id="companyMaterialLinksView" class="links-container">
                <div class="empty-state">No company-material links yet.</div>
            </div>
        </div>

        <!-- Paths Table -->
        <div class="card">
            <h3 class="card-title"><i class="fa-solid fa-route"></i> All Paths (<span id="totalPaths">0</span>)</h3>
            <div id="pathsTableContainer">
                <table class="paths-table hidden" id="pathsTable">
                    <thead>
                        <tr>
                            <th>Company</th>
                            <th>Material</th>
                            <th>Opening</th>
                            <th>Series</th>
                            <th>Color</th>
                            <th style="width: 60px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="pathsTableBody"></tbody>
                </table>
                <div id="noPathsYet" class="empty-state">
                    No paths created yet. Add a System Series to create paths.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div id="toastContainer"></div>
{% endblock %}

{% block extra_js %}
<script src="/static/js/relations.js?v=9"></script>
{% endblock %}
