{% extends "admin/base.html.jinja" %}
{% from "components/tables.html.jinja" import table_container with context %}
{% from "components/buttons.html.jinja" import button, button_group with context %}
{% from "admin/components/tooltip_component.html.jinja" import tooltip with context %}

{% block title %}Profile Entry - {{ super() }}{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="stylesheet" href="/static/css/profile-entry.css?v=23">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tippy.js@6.3.7/dist/tippy.css">
<style>
/* System Series Loading Indicator */
.loading-indicator {
    display: flex;
    align-items: center;
    min-width: 80px;
}

.loading-spinner-small {
    width: 16px;
    height: 16px;
    border: 2px solid #e5e7eb;
    border-top: 2px solid #3b82f6;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* Auto-populated Fields */
.auto-populated-field {
    position: relative;
}

.input-field.auto-populated {
    background-color: #f9fafb;
    border-color: #d1d5db;
    color: #6b7280;
    cursor: not-allowed;
}

.input-field.loading {
    background-color: #f3f4f6;
    color: #9ca3af;
}

.auto-selected-indicator {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 4px;
    padding: 2px 6px;
    background-color: #f0f9ff;
    border: 1px solid #e0f2fe;
    border-radius: 4px;
    font-size: 11px;
}

/* Colors Multi-Select */
.colors-multi-select {
    position: relative;
}

.colors-display {
    min-height: 40px;
    padding: 8px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background-color: #ffffff;
}

.colors-display.loading {
    background-color: #f3f4f6;
    color: #9ca3af;
}

.colors-display.auto-selected {
    background-color: #f9fafb;
    border-color: #d1d5db;
}

.colors-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 24px;
}

.selected-colors {
    min-height: 24px;
}

.color-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

.color-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    background-color: #fdf2f8;
    border: 1px solid #fce7f3;
    border-radius: 16px;
    font-size: 12px;
    color: #be185d;
}

.color-chip .remove-color {
    margin-left: 4px;
    padding: 0 4px;
    background: none;
    border: none;
    color: #be185d;
    cursor: pointer;
    font-weight: bold;
    border-radius: 50%;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
}

.color-chip .remove-color:hover {
    background-color: #be185d;
    color: white;
}

.manual-color-selection {
    margin-top: 8px;
}

/* Field Reordering Styles */
.form-section {
    display: flex;
    flex-direction: column;
}

.field-item[data-field="name"] {
    order: 1;
}

.field-item[data-field="type"] {
    order: 2;
}

.field-item[data-field="system_series"] {
    order: 3;
}

.field-item[data-field="company"] {
    order: 4;
}

.field-item[data-field="material"] {
    order: 5;
}

.field-item[data-field="opening_system"] {
    order: 6;
}

.field-item[data-field="colours"] {
    order: 7;
}

.field-item[data-field="code"] {
    order: 8;
}

/* All other fields maintain their natural order after the reordered ones */
.field-item:not([data-field="name"]):not([data-field="type"]):not([data-field="system_series"]):not([data-field="company"]):not([data-field="material"]):not([data-field="opening_system"]):not([data-field="colours"]):not([data-field="code"]) {
    order: 999;
}
</style>
{% endblock %}

{% block content %}
<div x-data="profileEntryApp({ 
    canEdit: {{ can_edit|tojson if can_edit is defined else 'false' }}, 
    canDelete: {{ can_delete|tojson if can_delete is defined else 'false' }} 
})" x-init="init()" class="space-y-6">

    <!-- Navigation Tabs -->
    <div class="navigation-tabs">
        <a href="/api/v1/admin/entry/profile" class="nav-tab active">
            👤 Profile
        </a>
        <a href="/api/v1/admin/entry/accessories" class="nav-tab">
            🧩 Accessories
        </a>
        <a href="/api/v1/admin/entry/glazing" class="nav-tab">
            🪟 Glazing
        </a>
    </div>

    <!-- Page Header -->
    <div class="bg-white rounded-lg shadow-md p-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Profile Data Entry</h1>
                <p class="text-gray-600 mt-1">Enter product profile information with real-time preview</p>
            </div>
        </div>
    </div>

    <!-- Loading State -->
    <div x-show="loading" class="text-center py-12">
        <div class="loading-spinner mx-auto mb-4" style="width: 2rem; height: 2rem;"></div>
        <p class="text-gray-600">Loading form schema...</p>
    </div>

    <!-- Error State -->
    <div x-show="error" class="bg-red-50 border border-red-200 rounded-lg p-4">
        <div class="flex items-center">
            <span class="text-red-500 mr-2 text-lg">⚠️</span>
            <span class="text-red-700" x-text="error"></span>
        </div>
    </div>

    <!-- Unsaved Data Indicator -->
    <div x-show="hasUnsavedData" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 transform -translate-y-2"
         x-transition:enter-end="opacity-100 transform translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-lg shadow-sm p-4">
        <div class="flex items-start gap-3">
            <div class="flex-shrink-0">
                <div class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center">
                    <span class="text-amber-600 text-lg">⏰ </span>
                </div>
            </div>
            <div class="flex-1">
                <h4 class="text-sm font-semibold text-amber-900 mb-1">Unsaved Changes</h4>
                <p class="text-sm text-amber-700">
                    Your changes are temporarily saved in this session. Click <strong>Record</strong> to save them permanently to the database.
                </p>
            </div>
            {{ button(
                text="✕",
                variant="ghost",
                size="sm",
                alpine_attrs='@click="hasUnsavedData = false"',
                class="close-notification-btn",
                title="Close",
                aria_label="Close notification"
            ) }}
        </div>
    </div>

    <!-- Tabbed Interface Layout -->
    <div x-show="schema && schema.sections && !loading" x-cloak class="tabbed-interface">
        <!-- Tab Buttons -->
        <div class="tab-buttons">
            <button @click="switchTab('input')" 
                    :class="{ 'active': activeTab === 'input' }"
                    type="button"
                    class="tab-btn active">
                📝 Input
            </button>
            <button @click="switchTab('preview')" 
                    :class="{ 'active': activeTab === 'preview' }"
                    type="button"
                    class="tab-btn">
                👁️ Preview
            </button>
        </div>
        
        <!-- Tab Content -->
        <div class="tab-content">
            <!-- Input Tab -->
            <div x-show="activeTab === 'input'" class="tab-pane" id="input-tab">
                <div class="simple-field-list">
                    <form @submit.prevent="saveConfiguration()">
                        <!-- Dynamic Form Fields -->
                        <template x-if="schema && schema.sections && schema.sections.length > 0">
                            <div x-data="{ debugSections: schema.sections }" 
                                 x-init="console.log('🦆 [ALPINE] ✨ LOUD DUCK DEBUG - Template init, sections:', debugSections.length, debugSections)">
                                <template x-for="section in schema.sections" :key="section.title">
                                    <div class="form-section mb-8" 
                                         x-data="{ debugSection: section }"
                                         x-init="console.log('🦆 [ALPINE] ✨ LOUD DUCK DEBUG - Rendering section:', debugSection.title, 'Fields:', debugSection.fields?.length)">
                                        <h3 class="text-lg font-semibold text-gray-800 border-b pb-2 mb-4" 
                                            x-text="section.title"
                                            x-show="section.fields.some(f => isFieldVisible(f.name))"></h3>
                                        <template x-for="field in section.fields" :key="field.name">
                                <div class="field-item" 
                                     :class="{ 
                                         'hidden': !isFieldVisible(field.name),
                                         'error': fieldErrors[field.name]
                                     }"
                                     :data-field="field.name"
                                     x-show="isFieldVisible(field.name)"
                                     x-transition:enter="transition ease-out duration-300"
                                     x-transition:enter-start="opacity-0 transform scale-95"
                                     x-transition:enter-end="opacity-100 transform scale-100">
                                    
                                    <!-- Field Label -->
                                    <label class="field-label" :for="field.name">
                                        <div class="flex items-center gap-2">
                                            <span x-text="field.label" :class="{ 'text-red-700': fieldErrors[field.name] }"></span>
                                            <span x-show="field.required" class="text-red-500">*</span>
                                            <template x-if="fieldErrors[field.name]">
                                                <i class="fas fa-exclamation-triangle text-red-500 text-sm animate-pulse"></i>
                                            </template>
                                            <template x-if="field.description">
                                                {{ tooltip(content="", alpine_binding="field.description", attrs='x-tooltip="field.description"') }}
                                            </template>
                                        </div>
                                    </label>
                                    
                                    <!-- Help Text -->
                                    <p x-show="field.help_text" class="field-help" x-text="field.help_text"></p>
                                    
                                    <!-- Native Alpine.js Field Rendering -->
                                    <div class="field-input-container">
                                        <!-- SELECT / DROPDOWN -->
                                        <template x-if="field.componentType === 'dropdown'">
                                            <div class="dynamic-select-container">
                                                <!-- System Series Dropdown with Loading Indicator -->
                                                <template x-if="field.name === 'system_series'">
                                                    <div class="system-series-container">
                                                        <div class="flex items-center gap-2">
                                                            <select :id="field.name" 
                                                                    class="input-field flex-1" 
                                                                    :class="{ 'invalid': fieldErrors[field.name] }"
                                                                    :value="formData[field.name] || ''"
                                                                    @change="handleSystemSeriesChange($event.target.value)"
                                                                    :disabled="loadingSystemSeriesData">
                                                                <option value="">Select System Series...</option>
                                                                <template x-if="field.options && field.options.length > 0">
                                                                    <template x-for="opt in field.options" :key="typeof opt === 'string' ? opt : opt.name || opt.id">
                                                                        <option :value="typeof opt === 'string' ? opt : opt.name" 
                                                                                :text="typeof opt === 'string' ? opt : opt.name" 
                                                                                :selected="formData[field.name] === (typeof opt === 'string' ? opt : opt.name)"></option>
                                                                    </template>
                                                                </template>
                                                                <template x-if="!field.options || field.options.length === 0">
                                                                    <option value="" disabled>Loading options...</option>
                                                                </template>
                                                            </select>
                                                            <!-- Loading Indicator -->
                                                            <div x-show="loadingSystemSeriesData" class="loading-indicator">
                                                                <div class="loading-spinner-small"></div>
                                                                <span class="text-xs text-gray-500 ml-1">Loading...</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </template>
                                                
                                                <!-- Auto-populated Fields (Material, Company, Opening System) -->
                                                <template x-if="field.name === 'material' || field.name === 'company' || field.name === 'opening_system'">
                                                    <div class="auto-populated-field">
                                                        <select :id="field.name" 
                                                                class="input-field auto-populated" 
                                                                :class="{ 
                                                                    'invalid': fieldErrors[field.name],
                                                                    'loading': loadingSystemSeriesData,
                                                                    'auto-selected': isAutoPopulated(field.name)
                                                                }"
                                                                :value="formData[field.name] || ''"
                                                                :disabled="isAutoPopulated(field.name) || loadingSystemSeriesData"
                                                                @change="updateField(field.name, $event.target.value)">
                                                            <option value="" x-show="loadingSystemSeriesData">Loading...</option>
                                                            <option value="" x-show="!loadingSystemSeriesData && !isAutoPopulated(field.name)">Select...</option>
                                                            <template x-for="opt in (field.options || [])" :key="typeof opt === 'string' ? opt : opt.name || opt.id">
                                                                <option :value="typeof opt === 'string' ? opt : opt.name" 
                                                                        :text="typeof opt === 'string' ? opt : opt.name" 
                                                                        :selected="formData[field.name] === (typeof opt === 'string' ? opt : opt.name)"></option>
                                                            </template>
                                                        </select>
                                                        <!-- Auto-selected indicator -->
                                                        <div x-show="isAutoPopulated(field.name)" class="auto-selected-indicator">
                                                            <i class="fas fa-lock text-xs text-gray-400"></i>
                                                            <span class="text-xs text-gray-500">Auto-selected from System Series</span>
                                                        </div>
                                                    </div>
                                                </template>
                                                
                                                <!-- Regular Dropdown Fields -->
                                                <template x-if="field.name !== 'system_series' && field.name !== 'material' && field.name !== 'company' && field.name !== 'opening_system' && field.name !== 'colours'">
                                                    <select :id="field.name" 
                                                            class="input-field" 
                                                            :class="{ 'invalid': fieldErrors[field.name] }"
                                                            :value="formData[field.name] || ''"
                                                            @change="updateField(field.name, $event.target.value)">
                                                        <option value="">Select...</option>
                                                        <template x-for="opt in (field.options || [])" :key="typeof opt === 'string' ? opt : opt.name || opt.id">
                                                            <option :value="typeof opt === 'string' ? opt : opt.name" 
                                                                    :text="typeof opt === 'string' ? opt : opt.name" 
                                                                    :selected="formData[field.name] === (typeof opt === 'string' ? opt : opt.name)"></option>
                                                        </template>
                                                    </select>
                                                </template>
                                                
                                                <!-- Colors Multi-Select (Special Handling) -->
                                                <template x-if="field.name === 'colours'">
                                                    <div class="colors-multi-select">
                                                        <div class="colors-display" 
                                                             :class="{ 
                                                                 'loading': loadingSystemSeriesData,
                                                                 'auto-selected': isAutoPopulated('colours')
                                                             }">
                                                            <!-- Loading State -->
                                                            <div x-show="loadingSystemSeriesData" class="colors-loading">
                                                                <span class="text-gray-500">Loading colors...</span>
                                                            </div>
                                                            
                                                            <!-- Selected Colors Display -->
                                                            <div x-show="!loadingSystemSeriesData" class="selected-colors">
                                                                <template x-if="!formData.colours || formData.colours.length === 0">
                                                                    <span class="text-gray-400 italic">No colors selected</span>
                                                                </template>
                                                                <template x-if="formData.colours && formData.colours.length > 0">
                                                                    <div class="color-chips">
                                                                        <template x-for="color in formData.colours" :key="color">
                                                                            <span class="color-chip">
                                                                                <i class="fas fa-palette text-pink-500"></i>
                                                                                <span x-text="color"></span>
                                                                                <button x-show="!isAutoPopulated('colours')" 
                                                                                        type="button" 
                                                                                        @click="removeColor(color)"
                                                                                        class="remove-color">×</button>
                                                                            </span>
                                                                        </template>
                                                                    </div>
                                                                </template>
                                                            </div>
                                                            
                                                            <!-- Manual Color Selection (when not auto-populated) -->
                                                            <div x-show="!isAutoPopulated('colours') && !loadingSystemSeriesData" class="manual-color-selection">
                                                                <select class="input-field mt-2" @change="addColor($event.target.value); $event.target.value = ''">
                                                                    <option value="">Add color...</option>
                                                                    <template x-for="opt in (field.options || [])" :key="typeof opt === 'string' ? opt : opt.name || opt.id">
                                                                        <option :value="typeof opt === 'string' ? opt : opt.name" 
                                                                                :text="typeof opt === 'string' ? opt : opt.name" 
                                                                                :disabled="(formData.colours || []).includes(typeof opt === 'string' ? opt : opt.name)"></option>
                                                                    </template>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        
                                                        <!-- Auto-selected indicator for colors -->
                                                        <div x-show="isAutoPopulated('colours')" class="auto-selected-indicator">
                                                            <i class="fas fa-lock text-xs text-gray-400"></i>
                                                            <span class="text-xs text-gray-500">Auto-selected from System Series</span>
                                                        </div>
                                                    </div>
                                                </template>
                                            </div>
                                        </template>

                                        <!-- MULTI-SELECT -->
                                        <template x-if="field.componentType === 'multi-select'">
                                            <div class="dynamic-select-container">
                                                <select :id="field.name" 
                                                        class="input-field" 
                                                        :class="{ 'invalid': fieldErrors[field.name] }"
                                                        multiple 
                                                        @change="updateMultiSelectField(field.name, $event.target)">
                                                    <template x-for="opt in getAllFieldOptions(field.name)" :key="typeof opt === 'string' ? opt : opt.name || opt.id">
                                                        <option :value="typeof opt === 'string' ? opt : opt.name" 
                                                                :text="typeof opt === 'string' ? opt : opt.name" 
                                                                :selected="(formData[field.name] || []).includes(typeof opt === 'string' ? opt : opt.name)"></option>
                                                    </template>
                                                </select>
                                                
                                                <!-- Dynamic Options Management -->
                                                <div class="dynamic-options-controls" style="margin-top: 8px;">
                                                    <!-- Add New Option -->
                                                    <div class="add-option-container" style="display: flex; gap: 8px; margin-bottom: 8px;">
                                                        <input type="text" 
                                                               :id="field.name + '_new_option'"
                                                               placeholder="Add new option..."
                                                               class="input-field"
                                                               style="flex: 1; font-size: 12px; padding: 4px 8px;"
                                                               @keydown.enter="addNewOption(field.name, $event.target.value); $event.target.value = ''">
                                                        <button type="button"
                                                                @click="addNewOption(field.name, document.getElementById(field.name + '_new_option').value); document.getElementById(field.name + '_new_option').value = ''"
                                                                class="btn-add-option"
                                                                style="padding: 4px 8px; background: #10b981 !important; color: white !important; border: none !important; border-radius: 4px !important; font-size: 12px !important; cursor: pointer !important;">
                                                            + Add
                                                        </button>
                                                    </div>
                                                    
                                                    <!-- Custom Options List with Delete Buttons -->
                                                    <div class="custom-options-list">
                                                        <template x-for="customOpt in getCustomOptions(field.name)" :key="customOpt">
                                                            <div class="custom-option-item" 
                                                                 style="display: flex !important; align-items: center !important; gap: 8px !important; padding: 4px 8px !important; background: #f3f4f6 !important; border-radius: 4px !important; margin-bottom: 4px !important; font-size: 12px !important;">
                                                                <span x-text="customOpt" style="flex: 1 !important; color: #374151 !important;"></span>
                                                                <button type="button"
                                                                        @click="removeCustomOption(field.name, customOpt)"
                                                                        class="btn-remove-option"
                                                                        style="padding: 2px 6px !important; background: #ef4444 !important; color: white !important; border: none !important; border-radius: 3px !important; font-size: 10px !important; cursor: pointer !important; line-height: 1 !important;"
                                                                        title="Remove this option">
                                                                    ✕
                                                                </button>
                                                            </div>
                                                        </template>
                                                    </div>
                                                </div>
                                            </div>
                                        </template>

                                        <!-- RADIO -->
                                        <template x-if="field.componentType === 'radio'">
                                            <div class="dynamic-radio-container">
                                                <div class="space-y-2">
                                                    <template x-for="opt in getAllFieldOptions(field.name)" :key="typeof opt === 'string' ? opt : opt.name || opt.id">
                                                        <label class="flex items-center space-x-2 cursor-pointer">
                                                            <input type="radio" 
                                                                   :name="field.name" 
                                                                   :value="typeof opt === 'string' ? opt : opt.name" 
                                                                   :checked="formData[field.name] === (typeof opt === 'string' ? opt : opt.name)"
                                                                   @change="updateField(field.name, typeof opt === 'string' ? opt : opt.name)" 
                                                                   class="text-blue-600 focus:ring-blue-500 border-gray-300">
                                                            <span class="text-gray-700" :text="typeof opt === 'string' ? opt : opt.name"></span>
                                                        </label>
                                                    </template>
                                                </div>
                                                
                                                <!-- Dynamic Options Management -->
                                                <div class="dynamic-options-controls" style="margin-top: 8px;">
                                                    <!-- Add New Option -->
                                                    <div class="add-option-container" style="display: flex; gap: 8px; margin-bottom: 8px;">
                                                        <input type="text" 
                                                               :id="field.name + '_new_option'"
                                                               placeholder="Add new option..."
                                                               class="input-field"
                                                               style="flex: 1; font-size: 12px; padding: 4px 8px;"
                                                               @keydown.enter="addNewOption(field.name, $event.target.value); $event.target.value = ''">
                                                        <button type="button"
                                                                @click="addNewOption(field.name, document.getElementById(field.name + '_new_option').value); document.getElementById(field.name + '_new_option').value = ''"
                                                                class="btn-add-option"
                                                                style="padding: 4px 8px; background: #10b981 !important; color: white !important; border: none !important; border-radius: 4px !important; font-size: 12px !important; cursor: pointer !important;">
                                                            + Add
                                                        </button>
                                                    </div>
                                                    
                                                    <!-- Custom Options List with Delete Buttons -->
                                                    <div class="custom-options-list">
                                                        <template x-for="customOpt in getCustomOptions(field.name)" :key="customOpt">
                                                            <div class="custom-option-item" 
                                                                 style="display: flex !important; align-items: center !important; gap: 8px !important; padding: 4px 8px !important; background: #f3f4f6 !important; border-radius: 4px !important; margin-bottom: 4px !important; font-size: 12px !important;">
                                                                <span x-text="customOpt" style="flex: 1 !important; color: #374151 !important;"></span>
                                                                <button type="button"
                                                                        @click="removeCustomOption(field.name, customOpt)"
                                                                        class="btn-remove-option"
                                                                        style="padding: 2px 6px !important; background: #ef4444 !important; color: white !important; border: none !important; border-radius: 3px !important; font-size: 10px !important; cursor: pointer !important; line-height: 1 !important;"
                                                                        title="Remove this option">
                                                                    ✕
                                                                </button>
                                                            </div>
                                                        </template>
                                                    </div>
                                                </div>
                                            </div>
                                        </template>

                                        <!-- CHECKBOX -->
                                        <template x-if="field.componentType === 'checkbox'">
                                            <label class="flex items-center space-x-2 cursor-pointer">
                                                <input type="checkbox" 
                                                       :id="field.name" 
                                                       :checked="formData[field.name] === true"
                                                       @change="updateField(field.name, $event.target.checked)" 
                                                       class="text-blue-600 rounded focus:ring-blue-500 border-gray-300">
                                                <span class="text-gray-700" x-text="field.label"></span>
                                            </label>
                                        </template>

                                        <!-- TEXTAREA -->
                                        <template x-if="field.componentType === 'textarea'">
                                            <textarea :id="field.name" 
                                                      class="input-field" 
                                                      :class="{ 'invalid': fieldErrors[field.name] }"
                                                      rows="3" 
                                                      :placeholder="'Enter ' + field.label.toLowerCase() + '...'" 
                                                      :value="formData[field.name] || ''"
                                                      @input="updateField(field.name, $event.target.value)"></textarea>
                                        </template>

                                        <!-- NUMBER -->
                                        <template x-if="field.componentType === 'number'">
                                            <div :class="getFieldUnit(field.name) ? 'input-group' : ''">
                                                <input type="number" 
                                                       :id="field.name" 
                                                       class="input-field" 
                                                       :class="{ 'invalid': fieldErrors[field.name] }"
                                                       :value="formData[field.name]"
                                                       :min="field.validation_rules?.min" 
                                                       :max="field.validation_rules?.max"
                                                       :step="field.data_type === 'float' ? '0.1' : '1'"
                                                       :placeholder="'Enter ' + field.label.toLowerCase() + '...'" 
                                                       @input="updateField(field.name, $event.target.value)">
                                                <template x-if="getFieldUnit(field.name)">
                                                    <span class="input-group-addon" x-text="getFieldUnit(field.name)"></span>
                                                </template>
                                            </div>
                                        </template>

                                        <!-- PERCENTAGE -->
                                        <template x-if="field.componentType === 'percentage'">
                                            <div class="input-group" :class="{ 'error-border': fieldErrors[field.name] }">
                                                <input type="number" 
                                                       :id="field.name" 
                                                       class="input-field" 
                                                       :class="{ 'invalid': fieldErrors[field.name] }"
                                                       :value="formData[field.name]"
                                                       min="0" max="100" step="0.1" 
                                                       placeholder="0" 
                                                       @input="updateField(field.name, $event.target.value)">
                                                <span class="input-group-addon">%</span>
                                            </div>
                                        </template>

                                        <!-- CURRENCY -->
                                        <template x-if="field.componentType === 'currency'">
                                            <div class="input-group" :class="{ 'error-border': fieldErrors[field.name] }">
                                                <span class="input-group-addon prefix">$</span>
                                                <input type="number" 
                                                       :id="field.name" 
                                                       class="input-field" 
                                                       :class="{ 'invalid': fieldErrors[field.name] }"
                                                       :value="formData[field.name]"
                                                       min="0" step="0.01" 
                                                       placeholder="0.00" 
                                                       @input="updateField(field.name, $event.target.value)">
                                            </div>
                                        </template>

                                        <!-- SLIDER -->
                                        <template x-if="field.componentType === 'slider'">
                                            <div class="space-y-2">
                                                <input type="range" 
                                                       :id="field.name" 
                                                       class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer" 
                                                       :value="formData[field.name] || (field.validation_rules?.min || 0)"
                                                       :min="field.validation_rules?.min || 0" 
                                                       :max="field.validation_rules?.max || 100" 
                                                       @input="updateField(field.name, $event.target.value)">
                                                <div class="flex justify-between text-sm text-gray-500">
                                                    <span x-text="field.validation_rules?.min || 0"></span>
                                                    <span class="font-medium text-blue-600" x-text="formData[field.name] || (field.validation_rules?.min || 0)"></span>
                                                    <span x-text="field.validation_rules?.max || 100"></span>
                                                </div>
                                            </div>
                                        </template>

                                        <!-- FILE UPLOAD -->
                                        <template x-if="field.componentType === 'file'">
                                            <div class="image-upload-wrapper">
                                                <!-- Elegant Upload Box -->
                                                <div class="image-upload-box" 
                                                     @click="document.getElementById(field.name).click()"
                                                     :class="{ 'has-image': imagePreviews[field.name] }">
                                                    <!-- Placeholder (shown when no image) -->
                                                    <div class="upload-placeholder" x-show="!imagePreviews[field.name]">
                                                        <i class="fas fa-cloud-upload-alt"></i>
                                                        <span>Upload</span>
                                                    </div>
                                                    <!-- Image Preview -->
                                                    <img x-show="imagePreviews[field.name]" 
                                                         :src="imagePreviews[field.name]" 
                                                         alt="Preview"
                                                         class="upload-preview-img">
                                                    <!-- Hover Overlay -->
                                                    <div class="upload-overlay" x-show="imagePreviews[field.name]">Change</div>
                                                </div>
                                                <input :id="field.name" 
                                                       type="file" 
                                                       class="hidden" 
                                                       accept="image/*" 
                                                       @change="handleFileChange(field.name, $event)" />
                                                <!-- Clear Button -->
                                                <button type="button" 
                                                        x-show="imagePreviews[field.name] || formData[field.name]"
                                                        @click="clearFile(field.name)" 
                                                        class="btn-clear-upload">
                                                    <i class="fas fa-times"></i> Clear
                                                </button>
                                            </div>
                                        </template>

                                        <!-- DEFAULT TEXT INPUT -->
                                        <template x-if="field.componentType === 'text'">
                                            <input type="text" 
                                                   :id="field.name" 
                                                   class="input-field" 
                                                   :class="{ 'invalid': fieldErrors[field.name] }"
                                                   :value="formData[field.name] || ''" 
                                                   :pattern="field.validation_rules?.pattern"
                                                   :placeholder="'Enter ' + field.label.toLowerCase() + '...'" 
                                                   @input="updateField(field.name, $event.target.value)">
                                        </template>
                                    </div>
                                    
                                    <!-- Field Error -->
                                    <div x-show="fieldErrors[field.name]" 
                                         class="field-error"
                                         x-transition:enter="transition ease-out duration-200"
                                         x-transition:enter-start="opacity-0 transform -translate-y-1"
                                         x-transition:enter-end="opacity-100 transform translate-y-0"
                                         x-text="fieldErrors[field.name]"></div>
                                    
                                    <!-- Field Success (optional) -->
                                    <div x-show="!fieldErrors[field.name] && field.required && formData[field.name] && formData[field.name] !== ''" 
                                         class="field-success">
                                        <i class="fas fa-check-circle mr-1"></i>Valid
                                    </div>
                                        </div>
                                    </template>
                                    </div>
                                </template>
                            </div>
                        </template>
                        
                        <!-- Loading message when no schema -->
                        <template x-if="!schema || !schema.sections || schema.sections.length === 0">
                            <div class="text-center py-12">
                                <div class="loading-spinner mx-auto mb-4" style="width: 2rem; height: 2rem;"></div>
                                <p class="text-gray-600">Loading form fields...</p>
                            </div>
                        </template>
                        
                        <!-- Action Buttons -->
                        {% call button_group(align="right", gap="md", class="w-full mt-10 pt-8 border-t border-gray-200") %}
                            <div x-show="!saving">
                                {{ button(
                                    text="💾 Record to Database",
                                    variant="primary",
                                    size="lg",
                                    alpine_attrs='@click="recordConfiguration()" :disabled="!hasUnsavedData || saving"',
                                    class="record-database-btn"
                                ) }}
                            </div>
                            <div x-show="saving">
                                {{ button(
                                    text="Recording...",
                                    variant="primary",
                                    size="lg",
                                    loading=true,
                                    disabled=true
                                ) }}
                            </div>
                        {% endcall %}
                    </form>
                </div>
            </div>

            <!-- Preview Tab -->
            <div x-show="activeTab === 'preview'" class="tab-pane" id="preview-tab" style="max-width: 100vw; overflow-x: hidden;">
                <!-- Commit Changes Button -->
                <div x-show="hasUnsavedEdits" 
                     class="mb-4 p-4 bg-amber-50 border border-amber-200 rounded-lg">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <span class="text-amber-600 mr-2 text-lg">⚠️</span>
                            <span class="text-amber-800 font-medium">You have unsaved table edits</span>
                        </div>
                        <div x-show="!committingChanges">
                            {{ button(
                                text="💾 Commit Changes",
                                variant="primary",
                                alpine_attrs='@click="commitTableChanges()" :disabled="committingChanges"',
                                class="commit-changes-btn"
                            ) }}
                        </div>
                        <div x-show="committingChanges">
                            {{ button(
                                text="Committing...",
                                variant="primary",
                                loading=true,
                                disabled=true
                            ) }}
                        </div>
                    </div>
                </div>

                <!-- Bulk Delete Button -->
                <div x-show="hasSelectedRows" 
                     class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <span class="text-red-600 mr-2 text-lg">🗑️</span>
                            <span class="text-red-800 font-medium" x-text="`${selectedRowsCount} configuration${selectedRowsCount > 1 ? 's' : ''} selected`"></span>
                        </div>
                        <div class="flex items-center space-x-2">
                            {{ button(
                                text="Clear Selection",
                                variant="outline",
                                alpine_attrs='@click="clearSelection()"',
                                class="clear-selection-btn"
                            ) }}
                            <div x-show="!bulkDeleting">
                                {{ button(
                                    text="🗑️ Delete Selected",
                                    variant="danger",
                                    alpine_attrs='@click="bulkDeleteSelected()" :disabled="bulkDeleting"'
                                ) }}
                            </div>
                            <div x-show="bulkDeleting">
                                {{ button(
                                    text="Deleting...",
                                    variant="danger",
                                    loading=true,
                                    disabled=true
                                ) }}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Viewport-Constrained Table Container -->
                <!-- Modern Search Interface -->
                <div class="search-interface">
                    <div class="search-header">
                        <h3 class="search-title">Configuration Search</h3>
                        <div class="flex items-center space-x-2">
                            <span x-show="searchResults.total > 0" class="search-results-counter">
                                <span class="filtered-count" x-text="searchResults.filtered"></span> of <span class="total-count" x-text="searchResults.total"></span> records
                            </span>
                            <button @click="toggleAdvancedSearch()" 
                                    type="button"
                                    class="advanced-search-toggle">
                                <span x-text="showAdvancedSearch ? 'Simple Search' : 'Advanced Search'"></span>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Search Controls -->
                    <div class="search-controls">
                        <div class="search-input-container">
                            <div class="search-input">
                                <input type="text" 
                                       x-model="searchQuery"
                                       @input="performSearch()"
                                       placeholder="Search across all columns..."
                                       class="w-full">
                                <div class="search-icon">
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                    </svg>
                                </div>
                                <button x-show="searchQuery" 
                                        @click="clearSearch()"
                                        type="button"
                                        class="clear-icon">
                                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <button @click="exportSearchResults()" 
                                :disabled="filteredConfigurations.length === 0"
                                type="button"
                                class="export-button">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            Export Results
                        </button>
                    </div>
                    
                    <!-- Advanced Search Panel -->
                    <div x-show="showAdvancedSearch" 
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 transform -translate-y-2"
                         x-transition:enter-end="opacity-100 transform translate-y-0"
                         x-transition:leave="transition ease-in duration-150"
                         x-transition:leave-start="opacity-100"
                         x-transition:leave-end="opacity-0 transform -translate-y-2"
                         class="advanced-search-panel">
                        <h4>Column-Specific Filters</h4>
                        <div class="grid">
                            <template x-for="header in previewHeaders.slice(0, 6)" :key="header">
                                <div class="filter-group">
                                    <label x-text="header"></label>
                                    <div class="column-filter">
                                        <input type="text" 
                                               :placeholder="'Filter by ' + header.toLowerCase() + '...'"
                                               :value="columnFilters[header] || ''"
                                               @input="setColumnFilter(header, $event.target.value)">
                                    </div>
                                </div>
                            </template>
                        </div>
                        <div class="advanced-search-actions">
                            <button @click="clearAllFilters()" 
                                    type="button"
                                    class="clear-filters-button">
                                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                </svg>
                                Clear All Filters
                            </button>
                            <div class="filter-info">
                                Showing first 6 columns. Use simple search for all columns.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Table Container -->
                <div class="w-full bg-white rounded-lg shadow-md border border-gray-200 responsive-table-container" style="overflow: visible;">
                    <div class="px-6 py-4 border-b border-gray-200">
                        <div>
                            <h3 class="text-lg font-semibold text-gray-900">Configuration Preview</h3>
                            <p class="text-sm text-gray-600 mt-1">Live preview of the current configuration as it will appear in the system</p>
                        </div>
                    </div>
                    
                    <!-- Loading State for Headers -->
                    <div x-show="!previewHeadersReady" class="text-center py-12">
                        <div class="loading-spinner mx-auto mb-4" style="width: 2rem; height: 2rem;"></div>
                        <p class="text-gray-600">Loading preview headers...</p>
                    </div>
                    
                    <!-- Horizontal Scroll Container with Viewport Constraints -->
                    <div x-show="previewHeadersReady" class="w-full overflow-x-auto responsive-table-scroll" style="overflow-y: visible;">
                        <table class="min-w-full divide-y divide-gray-200 responsive-table">
                            <thead class="bg-gradient-to-r from-gray-50 to-gray-100/50 border-b border-gray-200">
                                <tr>
                            <!-- Checkbox Column Header -->
                            <th class="px-4 py-3 text-left w-12">
                                <input type="checkbox" 
                                       :checked="selectAll"
                                       @change="toggleSelectAll()"
                                       class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                       title="Select All">
                            </th>
                            <template x-for="header in previewHeaders" :key="header">
                                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider whitespace-nowrap" 
                                    x-text="header" 
                                    :title="header.replace(/\\n/g, ' ')"></th>
                            </template>
                            <th x-show="canDelete" class="px-4 py-3 text-right text-xs font-semibold text-gray-700 uppercase tracking-wider sticky right-0 bg-gray-50 z-10 w-24">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <template x-for="row in filteredConfigurations" :key="row.id">
                            <tr class="border-b border-gray-100 transition-all duration-150 hover:bg-gray-50/50"
                                :class="{ 
                                    'search-highlight': isRowHighlighted(row),
                                    'bg-blue-50 border-blue-200': isRowSelected(row.id)
                                }">
                                
                                <!-- Checkbox Column -->
                                <td class="px-4 py-3 w-12">
                                    <input type="checkbox" 
                                           :checked="isRowSelected(row.id)"
                                           @change="toggleRowSelection(row.id)"
                                           class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                           :title="'Select row ' + row.id">
                                </td>
                                <template x-for="header in previewHeaders" :key="header">
                                    <td class="px-4 py-3 text-sm text-gray-900 border-r border-gray-100 relative group whitespace-nowrap"
                                        :data-row-id="row.id"
                                        :data-field="header"
                                        @dblclick="canEdit && startEditing(row.id, header, row[header])">
                                        
                                        <div x-show="editingCell.rowId !== row.id || editingCell.field !== header">
                                            <!-- Special handling for image fields -->
                                            <template x-if="header.toLowerCase() === 'pic' && row[header] && row[header] !== 'N/A'">
                                                <div class="flex items-center" x-init="console.log('🦆 [TEMPLATE DEBUG] Image template rendered for:', header, row[header])">
                                                    <img :src="getImageUrl(row[header])" 
                                                         :alt="'Image for ' + header"
                                                         class="h-12 w-12 object-cover rounded border shadow-sm cursor-pointer hover:shadow-md transition-shadow"
                                                         @click="openImageModal(getImageUrl(row[header]))"
                                                         @load="console.log('� [IMAGGE DEBUG] Image loaded successfully:', getImageUrl(row[header])); $event.target.style.display='block'; $event.target.nextElementSibling.style.display='none';"
                                                         @error="console.log('🦆 [IMAGE DEBUG] Image failed to load:', getImageUrl(row[header])); $event.target.style.display='none'; $event.target.nextElementSibling.style.display='flex';"
                                                         style="display: block;"
                                                         x-init="console.log('🦆 [IMG INIT] Image element initialized with src:', getImageUrl(row[header]))">
                                                    <div class="image-placeholder" style="display: none; width: 48px; height: 48px; background: #f3f4f6; border: 1px solid #d1d5db; border-radius: 4px; align-items: center; justify-content: center; font-size: 10px; color: #6b7280;">
                                                        <span>No Image</span>
                                                    </div>
                                                </div>
                                            </template>
                                            
                                            <!-- Default text display for non-image fields with search highlighting -->
                                            <template x-if="header.toLowerCase() !== 'pic' || !row[header] || row[header] === 'N/A'">
                                                <span :class="{ 'na-value': !row[header] || row[header] === 'N/A' }" 
                                                      x-html="highlightSearchTerm(row[header] || 'N/A', header)"></span>
                                            </template>
                                        </div>

                                        <div x-show="editingCell.rowId === row.id && editingCell.field === header" 
                                             @click.away="saveInlineEdit(row.id, header)"
                                             @keydown.escape="cancelEditing()">
                                            
                                            <!-- Special handling for image fields -->
                                            <template x-if="isImageField(header)">
                                                <div class="flex items-center space-x-2">
                                                    <input type="file" 
                                                           accept="image/*"
                                                           @change="handleInlineImageChange(row.id, header, $event)"
                                                           class="text-sm file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
                                                           x-init="setTimeout(() => $el.focus(), 10)">
                                                    <button @click="cancelEditing()" 
                                                            class="text-xs px-2 py-1 bg-gray-100 hover:bg-gray-200 rounded">
                                                        Cancel
                                                    </button>
                                                </div>
                                            </template>
                                            
                                            <!-- Dropdown fields -->
                                            <template x-if="!isImageField(header) && isDropdownField(header)">
                                                <select x-model="editingCell.value"
                                                        @change="saveInlineEdit(row.id, header)"
                                                        class="inline-edit-select"
                                                        x-init="setTimeout(() => $el.focus(), 10)">
                                                    <option value="">Select...</option>
                                                    <template x-for="opt in getFieldOptionsForHeader(header)" :key="opt">
                                                        <option :value="opt" x-text="opt" :selected="editingCell.value === opt"></option>
                                                    </template>
                                                </select>
                                            </template>
                                            
                                            <!-- Number fields (number, percentage, currency) -->
                                            <template x-if="!isImageField(header) && isNumberField(header)">
                                                <input type="number" 
                                                       x-model="editingCell.value"
                                                       @keydown.enter="saveInlineEdit(row.id, header)"
                                                       @blur="saveInlineEdit(row.id, header)"
                                                       :min="getFieldValidationRules(header).min"
                                                       :max="getFieldValidationRules(header).max"
                                                       :step="getFieldValidationRules(header).step || 0.01"
                                                       class="inline-edit-input inline-edit-number"
                                                       placeholder="0"
                                                       x-init="setTimeout(() => $el.focus(), 10)">
                                            </template>
                                            
                                            <!-- Checkbox fields -->
                                            <template x-if="!isImageField(header) && isCheckboxField(header)">
                                                <div class="inline-edit-checkbox-wrapper">
                                                    <label class="inline-edit-checkbox-label">
                                                        <input type="checkbox" 
                                                               :checked="editingCell.value === true || editingCell.value === 'yes' || editingCell.value === 'Yes'"
                                                               @change="editingCell.value = $event.target.checked ? 'yes' : 'no'; saveInlineEdit(row.id, header)"
                                                               class="inline-edit-checkbox">
                                                        <span x-text="editingCell.value === true || editingCell.value === 'yes' || editingCell.value === 'Yes' ? 'Yes' : 'No'"></span>
                                                    </label>
                                                </div>
                                            </template>
                                            
                                            <!-- Default text input for other fields -->
                                            <template x-if="!isImageField(header) && !isDropdownField(header) && !isNumberField(header) && !isCheckboxField(header)">
                                                <input type="text" 
                                                       x-model="editingCell.value"
                                                       @keydown.enter="saveInlineEdit(row.id, header)"
                                                       @blur="saveInlineEdit(row.id, header)"
                                                       class="inline-edit-input"
                                                       placeholder="Enter value..."
                                                       x-init="setTimeout(() => $el.focus(), 10)">
                                            </template>
                                        </div>
                                    </td>
                                </template>
                                <td x-show="canDelete" class="px-4 py-3 text-right text-sm font-medium sticky right-0 bg-white group-hover:bg-gray-50/50 z-10">
                                    {{ button(
                                        text="🗑️",
                                        variant="ghost",
                                        size="sm",
                                        alpine_attrs='@click="deleteRow(row.id)"',
                                        class="delete-row-btn",
                                        title="Delete Record"
                                    ) }}
                                </td>
                            </tr>
                        </template>
                        
                        <!-- Empty State -->
                        <template x-if="filteredConfigurations.length === 0 && savedConfigurations.length > 0">
                            <tr>
                                <td :colspan="previewHeaders.length + 1 + (canDelete ? 1 : 0)" class="px-4 py-12 text-center text-gray-500">
                                    <div class="flex flex-col items-center">
                                        <i class="fas fa-search text-4xl text-gray-200 mb-3"></i>
                                        <p class="text-lg font-medium mb-2">No results found</p>
                                        <p class="text-sm"> Try adjusting your search terms or filters</p>
                                    </div>
                                </td>
                            </tr>
                        </template>
                        
                        <!-- No Data State -->
                        <template x-if="savedConfigurations.length === 0">
                            <tr>
                                <td :colspan="previewHeaders.length + 1 + (canDelete ? 1 : 0)" class="px-4 py-12 text-center text-gray-500">
                                    <div class="flex flex-col items-center">
                                        <i class="fas fa-table text-4xl text-gray-200 mb-3"></i>
                                        <p>No saved configurations found for this product type.</p>
                                    </div>
                                </td>
                            </tr>
                        </template>
                    </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Pass server-side data to JavaScript
window.INITIAL_MANUFACTURING_TYPE_ID = {{ manufacturing_type_id or 'null' }};
window.INITIAL_PAGE_TYPE = {{ page_type|tojson if page_type is defined else '"profile"' }};

document.addEventListener('alpine:init', () => {
    // Add a custom directive for tooltips
    Alpine.directive('tooltip', (el, { expression }, { evaluate }) => {
        const content = evaluate(expression);
        if (!content) return;
        
        tippy(el, {
            content: content,
            theme: 'custom',
            allowHTML: true,
            delay: [200, 0],
            interactive: true,
            appendTo: () => document.body
        });
    });
    
    // Extend the existing profileEntryApp with System Series functionality
    const originalProfileEntryApp = window.profileEntryApp;
    window.profileEntryApp = function(config) {
        const baseApp = originalProfileEntryApp(config);
        
        return {
            ...baseApp,
            
            // System Series related state
            loadingSystemSeriesData: false,
            autoPopulatedFields: new Set(),
            
            // Handle System Series selection change
            async handleSystemSeriesChange(systemSeriesValue) {
                console.log('🔗 [SYSTEM SERIES] Selected:', systemSeriesValue);
                
                // Update the field value first
                this.updateField('system_series', systemSeriesValue);
                
                if (!systemSeriesValue) {
                    // Clear auto-populated fields if no system series selected
                    this.clearAutoPopulatedFields();
                    return;
                }
                
                // Start loading
                this.loadingSystemSeriesData = true;
                
                try {
                    // Get system series ID from the options data
                    const systemSeriesId = this.getSystemSeriesId(systemSeriesValue);
                    
                    if (!systemSeriesId) {
                        console.warn('🔗 [SYSTEM SERIES] Could not find ID for:', systemSeriesValue);
                        return;
                    }
                    
                    // Call the relations API to get dependent options
                    const response = await fetch('/api/v1/admin/relations/options', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            system_series_id: systemSeriesId
                        })
                    });
                    
                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }
                    
                    const data = await response.json();
                    console.log('🔗 [SYSTEM SERIES] API Response:', data);
                    
                    if (data.success && data.options) {
                        this.populateRelatedFields(data.options);
                    } else {
                        console.warn('🔗 [SYSTEM SERIES] Invalid API response:', data);
                        this.showToast('Failed to load related data', 'error');
                    }
                    
                } catch (error) {
                    console.error('🔗 [SYSTEM SERIES] Error loading related data:', error);
                    this.showToast('Error loading related data: ' + error.message, 'error');
                } finally {
                    this.loadingSystemSeriesData = false;
                }
            },
            
            // Get System Series ID from the field options data
            getSystemSeriesId(systemSeriesName) {
                // Look for system_series field in schema
                for (const section of this.schema?.sections || []) {
                    for (const field of section.fields || []) {
                        if (field.name === 'system_series' && field.options_data) {
                            const option = field.options_data.find(opt => opt.name === systemSeriesName);
                            return option?.id;
                        }
                    }
                }
                
                // Fallback: try to find in the options array (simple string array)
                console.warn('🔗 [SYSTEM SERIES] Could not find options_data, using fallback method');
                return null;
            },
            
            // Populate related fields from API response
            populateRelatedFields(options) {
                console.log('🔗 [POPULATE] Populating fields with:', options);
                
                // Clear previous auto-populated fields
                this.autoPopulatedFields.clear();
                
                // Populate material
                if (options.material && options.material.length > 0) {
                    const material = options.material[0]; // Take first material
                    this.updateField('material', material.name || material);
                    this.autoPopulatedFields.add('material');
                }
                
                // Populate company  
                if (options.company && options.company.length > 0) {
                    const company = options.company[0]; // Take first company
                    this.updateField('company', company.name || company);
                    this.autoPopulatedFields.add('company');
                }
                
                // Populate opening system
                if (options.opening_system && options.opening_system.length > 0) {
                    const openingSystem = options.opening_system[0]; // Take first opening system
                    this.updateField('opening_system', openingSystem.name || openingSystem);
                    this.autoPopulatedFields.add('opening_system');
                }
                
                // Populate colors (multiple)
                if (options.color && options.color.length > 0) {
                    const colors = options.color.map(c => c.name || c);
                    this.updateField('colours', colors);
                    this.autoPopulatedFields.add('colours');
                }
                
                console.log('🔗 [POPULATE] Auto-populated fields:', Array.from(this.autoPopulatedFields));
            },
            
            // Clear auto-populated fields
            clearAutoPopulatedFields() {
                console.log('🔗 [CLEAR] Clearing auto-populated fields');
                
                for (const fieldName of this.autoPopulatedFields) {
                    if (fieldName === 'colours') {
                        this.updateField(fieldName, []);
                    } else {
                        this.updateField(fieldName, '');
                    }
                }
                
                this.autoPopulatedFields.clear();
            },
            
            // Check if field is auto-populated
            isAutoPopulated(fieldName) {
                return this.autoPopulatedFields.has(fieldName);
            },
            
            // Add color to colors array
            addColor(colorName) {
                if (!colorName || this.isAutoPopulated('colours')) return;
                
                const currentColors = this.formData.colours || [];
                if (!currentColors.includes(colorName)) {
                    this.updateField('colours', [...currentColors, colorName]);
                }
            },
            
            // Remove color from colors array
            removeColor(colorName) {
                if (this.isAutoPopulated('colours')) return;
                
                const currentColors = this.formData.colours || [];
                const updatedColors = currentColors.filter(c => c !== colorName);
                this.updateField('colours', updatedColors);
            }
        };
    };
});
</script>
{% endblock %}

